	local function viewPlayer(target)
		local cam = workspace.CurrentCamera
		if isViewing then
			cam.CameraType = Enum.CameraType.Custom
			local myChar = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
			cam.CameraSubject = myChar:WaitForChild("Humanoid")
			isViewing = false
		else
			if not target or not target.Character then return end
			cam.CameraType = Enum.CameraType.Watch
			cam.CameraSubject = target.Character:WaitForChild("Humanoid")
			isViewing = true
			target.CharacterAdded:Connect(function(char)
				if isViewing then
					task.wait(0.5)
					cam.CameraSubject = char:WaitForChild("Humanoid")
				end
			end)
		end
	end

