local function ZITD_fake_script() -- ImageButton_6.LocalScript 
	local script = Instance.new('LocalScript', ImageButton_6)

	local Players = game:GetService("Players")
	local RunService = game:GetService("RunService")
	local UserInputService = game:GetService("UserInputService")

	local player = Players.LocalPlayer
	local ToggleButton = script.Parent

	local NOCLIP_KEY = Enum.KeyCode.N

	local enabled = false
	local noclip = false

	local character
	local connections = {}
	local originalCollision = {}

	local function disconnectCharacterConnections()
		for _, conn in ipairs(connections) do
			if conn then
				conn:Disconnect()
			end
		end
		table.clear(connections)
	end

	local function cacheCollisionStates()
		table.clear(originalCollision)

		if not character then return end
		for _, obj in ipairs(character:GetDescendants()) do
			if obj:IsA("BasePart") then
				originalCollision[obj] = obj.CanCollide
			end
		end
	end

	local function setNoclipState(state)
		if not character then return end

		for _, obj in ipairs(character:GetDescendants()) do
			if obj:IsA("BasePart") then
				if state then
					obj.CanCollide = false
				else
					if originalCollision[obj] ~= nil then
						obj.CanCollide = originalCollision[obj]
					end
				end
			end
		end
	end

	local function updateButton()
		ToggleButton.BackgroundColor3 = enabled
			and Color3.fromRGB(0, 255, 0)
			or Color3.fromRGB(255, 0, 0)
	end

	local function onDescendantAdded(obj)
		if obj:IsA("BasePart") then
			originalCollision[obj] = obj.CanCollide

			if enabled and noclip then
				obj.CanCollide = false
			end
		end
	end

	local function onCharacterAdded(char)
		disconnectCharacterConnections()

		character = char
		noclip = false

		cacheCollisionStates()

		table.insert(connections, character.DescendantAdded:Connect(onDescendantAdded))
	end

	player.CharacterAdded:Connect(onCharacterAdded)

	if player.Character then
		onCharacterAdded(player.Character)
	end

	ToggleButton.MouseButton1Click:Connect(function()
		enabled = not enabled

		if not enabled then
			noclip = false
			setNoclipState(false)
		end

		updateButton()
	end)

	UserInputService.InputBegan:Connect(function(input, gameProcessed)
		if gameProcessed then return end
		if input.KeyCode ~= NOCLIP_KEY then return end
		if not enabled then return end

		noclip = not noclip
		setNoclipState(noclip)
	end)

	RunService.Stepped:Connect(function()
		if enabled and noclip and character then
			for _, obj in ipairs(character:GetDescendants()) do
				if obj:IsA("BasePart") then
					obj.CanCollide = false
				end
			end
		end
	end)

	updateButton()
end
