-- Scripts:

local function ZUSCBGI_fake_script() -- ImageButton.LocalScript 
	local script = Instance.new('LocalScript', ImageButton)

	local Players = game:GetService("Players")
	local UserInputService = game:GetService("UserInputService")
	local RunService = game:GetService("RunService")

	local player = Players.LocalPlayer
	local camera = workspace.CurrentCamera

	local ToggleButton = script.Parent

	local TOGGLE_KEY = Enum.KeyCode.T
	local MAX_DISTANCE = 400            -- studs
	local LOCK_RADIUS = 300             -- pixels from crosshair
	local SMOOTHNESS = 28               -- higher = tighter lock
	local PREDICTION = 0.16             -- increase if WalkSpeed is crazy fast
	-- ====================

	local enabled = false

	local lockedChar = nil
	local lockedPart = nil
	local aimPos = nil
	local locked = false

	local function updateButton()
		if enabled then
			ToggleButton.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
		else
			ToggleButton.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
		end
	end

	local function clearLock()
		locked = false
		lockedPart = nil
		lockedChar = nil
		aimPos = nil
	end

	-- ===== Your original utilities (unchanged) =====
	local function getTorso(char)
		return char:FindFirstChild("UpperTorso")
			or char:FindFirstChild("Torso")
			or char:FindFirstChild("HumanoidRootPart")
	end

	local function alive(char)
		local hum = char:FindFirstChildOfClass("Humanoid")
		return hum and hum.Health > 0
	end

	local function screenDistance(worldPos)
		local v, onScreen = camera:WorldToViewportPoint(worldPos)
		if not onScreen then return math.huge end
		local center = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)
		return (Vector2.new(v.X, v.Y) - center).Magnitude
	end

	local function findTarget()
		local myChar = player.Character
		local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
		if not myRoot then return end

		local best, bestScore

		for _, plr in ipairs(Players:GetPlayers()) do
			if plr ~= player and plr.Character and alive(plr.Character) then
				local part = getTorso(plr.Character)
				if part then
					local dist = (part.Position - myRoot.Position).Magnitude
					if dist <= MAX_DISTANCE then
						local sDist = screenDistance(part.Position)
						if sDist <= LOCK_RADIUS then
							local score = sDist + dist * 0.04
							if not bestScore or score < bestScore then
								bestScore = score
								best = part
							end
						end
					end
				end
			end
		end

		return best
	end
	-- ==============================================

	ToggleButton.MouseButton1Click:Connect(function()
		enabled = not enabled
		if not enabled then
			clearLock() -- if you turn it OFF, it stops locking immediately
		end
		updateButton()
	end)

	UserInputService.InputBegan:Connect(function(input, gp)
		if gp then return end
		if input.KeyCode ~= TOGGLE_KEY then return end
		if not enabled then return end

		if locked then
			clearLock()
		else
			local part = findTarget()
			if part then
				locked = true
				lockedPart = part
				lockedChar = part.Parent
				aimPos = part.Position
			end
		end
	end)

	RunService.RenderStepped:Connect(function(dt)
		if not enabled then return end
		if not locked then return end

		if not lockedChar or not alive(lockedChar) then
			clearLock()
			return
		end

		lockedPart = getTorso(lockedChar)
		if not lockedPart then
			clearLock()
			return
		end

		local vel = lockedPart.AssemblyLinearVelocity
		local predicted = lockedPart.Position + vel * PREDICTION

		aimPos = aimPos or predicted
		local alpha = 1 - math.exp(-SMOOTHNESS * dt)
