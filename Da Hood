	local teleportBtn = targetFrame:WaitForChild("Teleport"):WaitForChild("ImageButton")
	local viewBtn = targetFrame:WaitForChild("View"):WaitForChild("ImageButton")
	local headsitBtn = targetFrame:WaitForChild("HeadSit"):WaitForChild("ImageButton")

	local Players = game:GetService("Players")
	local LocalPlayer = Players.LocalPlayer
	local weld
	local selectedTarget = nil
	local isViewing = false

	-- Find target from server
	local function findTarget(input)
		for _, v in pairs(Players:GetPlayers()) do
			if v ~= LocalPlayer and v.Name:lower():find(input:lower()) then
				return v
			end
		end
		return nil
	end

	-- Update PFP from in-game player
	local function updatePFP(player)
		if player then
			imageLabel.Image = "https://www.roblox.com/headshot-thumbnail/image?userId=" .. player.UserId .. "&width=150&height=150&format=png"
			selectedTarget = player
		else
			imageLabel.Image = ""
			selectedTarget = nil
		end
	end

	-- Auto-show first server player on open
	task.spawn(function()
		task.wait(1)
		local list = {}
		for _, v in pairs(Players:GetPlayers()) do
			if v ~= LocalPlayer then table.insert(list, v) end
		end
		if #list > 0 then
			textBox.Text = list[1].Name
			updatePFP(list[1])
		end
	end)

	-- Update target as you type
	textBox:GetPropertyChangedSignal("Text"):Connect(function()
		updatePFP(findTarget(textBox.Text))
	end)

	-- New player joins
	Players.PlayerAdded:Connect(function(p)
		if textBox.Text == "" then
			textBox.Text = p.Name
			updatePFP(p)
		end
	end)

	-- FLING
	local function strongFling(target)
		if not target or not target.Character then return end
		local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
		local hrp = char:WaitForChild("HumanoidRootPart")
		local tHRP = target.Character:FindFirstChild("HumanoidRootPart")
		if not tHRP then return end
		local oldCF = hrp.CFrame
		for i = 1, 150 do
			hrp.CFrame = tHRP.CFrame * CFrame.Angles(0, math.rad(i * 50), 0) * CFrame.new(0, 0, 3)
			hrp.Velocity = Vector3.new(10000, 10000, 10000)
			hrp.RotVelocity = Vector3.new(10000, 10000, 10000)
			task.wait()
		end
		hrp.CFrame = oldCF
	end

	-- TELEPORT
	local function teleportToTarget(target)
		if not target or not target.Character then return end
		local myChar = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
		local myHRP = myChar:WaitForChild("HumanoidRootPart")
		myHRP.CFrame = target.Character.HumanoidRootPart.CFrame + Vector3.new(0, 3, 0)
		target.CharacterAdded:Connect(function()
			task.wait(0.5)
			local newHRP = target.Character:WaitForChild("HumanoidRootPart")
			myHRP.CFrame = newHRP.CFrame + Vector3.new(0, 3, 0)
		end)
	end

